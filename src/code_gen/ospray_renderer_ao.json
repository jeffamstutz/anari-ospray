{
  "info": {
  "name": "OSPRAY_RENDERER_AO",
  "type": "extension",
  "dependencies" : ["anari_core_1_0"],
  "implements" : [
    "khr_renderer_background_color",
    "khr_renderer_background_image",
    "khr_renderer_ambient_light"
  ]
  },
 "objects": [
  {
   "name": "ao",
   "description": "The Ambient Occlusion renderer supports a subset of the SciVis renderer features for performance. Its main shading method is ambient occlusion, lights are not considered, and volume rendering is supported.",
   "properties": [],
   "type": "ANARI_RENDERER",
   "parameters": [
    {
     "name": "pixelSamples",
     "tags": [],
     "default": 1,
     "minimum": 1,
     "description": "samples per pixel",
     "types": [
      "ANARI_INT32"
     ]
    },
    {
     "name": "maxPathLength",
     "tags": [],
     "default": 20,
     "description": "maximum ray recursion depth",
     "types": [
      "ANARI_INT32"
     ]
    },
    {
     "name": "minContribution",
     "tags": [],
     "default": 0.001,
     "description": "sample contributions below this value will be neglected to speedup rendering",
     "types": [
      "ANARI_FLOAT32"
     ]
    },
    {
     "name": "varianceThreshold",
     "tags": [],
     "default": 0.0,
     "description": "threshold for adaptive accumulation",
     "types": [
      "ANARI_FLOAT32"
     ]
    },
    {
     "name": "aoSamples",
     "tags": [],
     "default": 1,
     "description": "number of rays per sample to compute ambient occlusion",
     "types": [
      "ANARI_INT32"
     ]
    },
    {
     "name": "aoDistance",
     "tags": [],
     "default": 1e20,
     "description": "maximum distance to consider for ambient occlusion",
     "types": [
      "ANARI_FLOAT32"
     ]
    },
    {
     "name": "aoIntensity",
     "tags": [],
     "default": 1.0,
     "minimum": 0.0,
     "maximum": 1.0,
     "description": "ambient occlusion strength",
     "types": [
      "ANARI_FLOAT32"
     ]
    },
    {
     "name": "volumeSamplingRate",
     "tags": [],
     "default": 1.0,
     "description": "sampling rate for volumes",
     "types": [
      "ANARI_FLOAT32"
     ]
    },
    {
     "name": "denoise",
     "tags": [],
     "default": false,
     "description": "enable Open Image Denoise (OIDN)",
     "types": [
      "ANARI_BOOL"
     ]
    },
    {
     "name": "denoiseAlpha",
     "tags": [],
     "default": false,
     "description": "whether to denoise the alpha channel as well",
     "types": [
      "ANARI_BOOL"
     ]
    },
    {
     "name": "denoiseQuality",
     "tags": [],
     "default": "medium",
     "values" : ["low", "medium", "high"],
     "description": "denoiser quality",
     "types": [
      "ANARI_STRING"
     ]
    }
   ]
  }
 ]
}
